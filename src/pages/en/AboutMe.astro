---
import Technologies from "./Technologies.astro";

const Backend = [
  "https://upload.wikimedia.org/wikipedia/commons/thumb/7/7d/Microsoft_.NET_logo.svg/800px-Microsoft_.NET_logo.svg.png",
  "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c3/Python-logo-notext.svg/800px-Python-logo-notext.svg.png",
  "https://miro.medium.com/v2/resize:fit:2560/1*2XrX0fP0htyTCah7AglTig.jpeg",
];

const Frontend = [
  "https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/React.svg/1200px-React.svg.png",
  "https://upload.wikimedia.org/wikipedia/commons/thumb/c/cf/Angular_full_color_logo.svg/1200px-Angular_full_color_logo.svg.png",
  "https://astro.js.org/astro.png",
  "https://upload.wikimedia.org/wikipedia/commons/thumb/9/99/Unofficial_JavaScript_logo_2.svg/1200px-Unofficial_JavaScript_logo_2.svg.png",
  "https://titrias.com/files/2022/04/typescript.png",
];

const baseDeDatos = [
  "https://media.datacenterdynamics.com/media/images/oracle_cloud.width-880.png",
  "https://www.svgrepo.com/show/303251/mysql-logo.svg",
  "https://ipappg.edu.pe/blog/wp-content/uploads/2022/05/mssqlserver.png",
  "https://cdn.iconscout.com/icon/free/png-256/free-mongodb-3521676-2945120.png?f=webp",
];
---

<article
  class="mt-10 flex flex-col items-center justify-center gap-8 text-gray-700 dark:text-gray-300 md:flex-row"
>
  <div
    class="[&>p]:mb-4 [&>p>strong]:text-yellow-500 dark:[&>p>strong]:text-yellow-100 [&>p>strong]:font-normal [&>p>strong]:font-mono text-pretty order-2 md:order-1"
  >
    <p class="w-full">
      Hello everyone! My name is Odiseo Esmerlin Rincón Sánchez and I've been
      passionate about programming since I was 17 years old. Now, with
      dedication and effort, I have become a <strong>Software Developer</strong
      >.
    </p>

    <p>
      My journey in the world of development began when I studied at the
      prestigious Instituto Tecnológico de Las Américas (ITLA). During my time
      there, I not only gained solid knowledge in software development, but also
      cultivated technical and creative skills that allow me to tackle any
      challenge in this exciting field.
    </p>

    <hr class="mt-5" />
    <h1 class="text-5xl mt-10">
      <i class="fa-solid fa-microchip"></i>
      <strong>Tecnologies</strong>
    </h1>

    <Technologies>
      <div class="">
        <strong class="text-3xl text-blue-200"
          ><i class="fa-solid fa-server"></i> Backend</strong
        >
        <div class="grid grid-cols-3 gap-4">
          {
            Backend.map((item) => (
              <div class="">
                <div class="flex justify-center mt-5">
                  <img
                    class="rounded-full shadow-lg size-16"
                    src={item}
                    alt="imagen"
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </Technologies>

    <Technologies>
      <div class="">
        <strong class="text-3xl text-yellow-200"
          ><i class="fa-solid fa-palette"></i> Frontend</strong
        >
        <div class="grid grid-cols-3 gap-4">
          {
            Frontend.map((item) => (
              <div class="">
                <div class="flex justify-center mt-5">
                  <img
                    class="rounded-full shadow-lg size-16"
                    src={item}
                    alt="imagen"
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </Technologies>

    <Technologies>
      <div class="">
        <strong class="text-3xl text-red"
          ><i class="fa-solid fa-database"></i>Data Bases</strong
        >
        <div class="grid grid-cols-3 gap-4">
          {
            baseDeDatos.map((item) => (
              <div class="">
                <div class="flex justify-center mt-5">
                  <img
                    class="rounded-full shadow-lg size-16"
                    src={item}
                    alt="imagen"
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </Technologies>

    <p
      class="mt-6 text-xl text-gray-800 dark: [&>strong]:font-semibold dark:text-gray-300"
    >
      <strong class="text-3xl text-yellow-200">
        Tambien tengo experiencia en:
      </strong>

      <ul>
        <li>Gestion de proyectos de Software</li>
        <li>Metodologias agiles</li>
        <li>DevOps</li>
        <li class="h-20">Implementacion de Arquitecturas de Software</li>
      </ul>
    </p>
  </div>
</article>

